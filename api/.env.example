# MT5 Configuration
MT5_LOGIN=123456
MT5_PASSWORD=replace-with-broker-password
MT5_SERVER=Broker-Real
MT5_DOCKER_HOST=localhost
MT5_DOCKER_PORT=8001

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
DEBUG=false

# Strategy Lab dark-launch flags (all disabled by default)
STRATEGY_LAB_ENABLED=false
OPEN_SIGNUP_ENABLED=false
CODEX_BUILDER_ENABLED=false
PAPER_LIVE_ENABLED=false
PUBLIC_STRATEGY_PUBLISHING_ENABLED=false

# Database
DATABASE_URL=sqlite+aiosqlite:///./trade_history.db

# Persistent runtime data directory (mount this in Dokploy)
BOT_DATA_DIR=/app/data

# Optional explicit bot state file path (defaults to $BOT_DATA_DIR/bot_state.json)
BOT_STATE_FILE=/app/data/bot_state.json

# Clerk Access
# Set CLERK_SECRET_KEY to enable Clerk-authenticated API requests.
CLERK_SECRET_KEY=
CLERK_ISSUER=
CLERK_JWT_KEY=
CLERK_JWKS_URL=
CLERK_AUTHORIZED_PARTIES=http://localhost:3000

# Optional comma-separated allowlist for the first Clerk owner bootstrap.
ACCESS_BOOTSTRAP_EMAILS=owner@example.com
