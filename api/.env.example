# MT5 Configuration
MT5_LOGIN=123456
MT5_PASSWORD=replace-with-broker-password
MT5_SERVER=Broker-Real
MT5_DOCKER_HOST=localhost
MT5_DOCKER_PORT=8001

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
DEBUG=false

# Product dark-launch flags (all disabled by default)
STRATEGY_LAB_ENABLED=false
OPEN_SIGNUP_ENABLED=false
CODEX_BUILDER_ENABLED=false
PAPER_LIVE_ENABLED=false
PUBLIC_STRATEGY_PUBLISHING_ENABLED=false

# PostgreSQL is required for copy-trading marketplace data.
DATABASE_URL=postgresql://signal_copier:replace-me@localhost:5432/signal_copier

# Isolated copy-runtime control plane. Keep these server-side.
COPY_RUNTIME_INGEST_TOKEN=replace-with-runtime-ingest-token
COPY_RUNTIME_MANAGER_URL=http://copy-runtime-manager:8080
COPY_RUNTIME_MANAGER_TOKEN=replace-with-runtime-manager-token

# Persistent compatibility data directory and one-time legacy archive source.
TRADING_DATA_DIR=/app/data

# WorkOS identity verification and User Management invitations.
WORKOS_API_KEY=sk_test_replace_me
WORKOS_CLIENT_ID=client_replace_me
WORKOS_ISSUER=https://api.workos.com/
# Optional override. The default is derived from WORKOS_CLIENT_ID.
WORKOS_JWKS_URL=

# Must exactly match the private value configured on the dashboard service.
DASHBOARD_PROXY_SECRET=replace-with-an-independent-random-secret

# Optional comma-separated allowlist for the first WorkOS owner bootstrap.
ACCESS_BOOTSTRAP_EMAILS=owner@example.com
# Recommended in production: only invited users may create dashboard access.
ACCESS_REQUIRE_INVITE=true
