NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_STRATEGY_LAB_ENABLED=false

# Public UI/middleware cutover switch. This does NOT activate the server; the
# private BETTER_AUTH_ENABLED + STRATEGY_LAB_ENABLED gates below still apply.
# Set false to roll the UI, middleware, provider, and API token path back to Clerk.
NEXT_PUBLIC_BETTER_AUTH_ENABLED=false
NEXT_PUBLIC_OPEN_SIGNUP_ENABLED=false
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Clerk rollback access
# Required only while the public Better Auth cutover switch is false.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Better Auth foundation (dormant until both server flags are true).
# Keep OPEN_SIGNUP_ENABLED=false until all release gates have passed.
BETTER_AUTH_ENABLED=false
STRATEGY_LAB_ENABLED=false
OPEN_SIGNUP_ENABLED=false
BETTER_AUTH_URL=
BETTER_AUTH_SECRET=
BETTER_AUTH_DATABASE_URL=
BETTER_AUTH_JWT_AUDIENCE=
BETTER_AUTH_TRUSTED_ORIGINS=

# Migration/integration tests only. This database is destructively reset by the
# opt-in PostgreSQL auth suite; never point it at production or shared data.
TEST_DATABASE_URL=

# Auth email delivery. Values are required only when Better Auth is enabled.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Required whenever Better Auth is enabled; also gates open signup.
TURNSTILE_SECRET_KEY=
